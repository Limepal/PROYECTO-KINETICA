# Database config (replace with your values)
POSTGRES_PORT=5432
POSTGRES_DB=kinetica
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_password_here

# JWT secret (REQUIRED - generate a secure random string)
APP_SECURITY_JWT_SECRET=your_256_bit_secret_key_min_32_chars_here

# Media storage and retention
KINETICA_MEDIA_STORAGE_ROOT=./storage/media
KINETICA_MEDIA_RETENTION_DAYS=30
KINETICA_MEDIA_RETENTION_SCAN_MS=3600000

# KPI threshold
KINETICA_KPI_LOW_CONFIDENCE_THRESHOLD=0.65

# Gloss conversion provider: stub | github
KINETICA_GLOSS_PROVIDER=github

# GitHub Models (only required when KINETICA_GLOSS_PROVIDER=github)
GITHUB_MODELS_URL=https://models.github.ai/inference
MODEL_ID=openai/gpt-4o-mini
GITHUB_TOKEN=
